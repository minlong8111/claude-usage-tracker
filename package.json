{
  "name": "claude-token-vibe-check",
  "displayName": "Claude Token Vibe Check",
  "description": "Monitor Claude Code usage, costs in VS Code",
  "icon": "images/icon.png",
  "version": "0.2.1",
  "publisher": "longmap813",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/minlong8111/claude-token-vibe-check"
  },
  "keywords": [
    "claude",
    "budget",
    "cost",
    "monitor",
    "token",
    "usage",
    "ai"
  ],
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "claudeBudget.openDashboard",
        "title": "Claude Tracker: Open Dashboard"
      },
      {
        "command": "claudeBudget.setDailyBudget",
        "title": "Claude Tracker: Set Daily Budget"
      },
      {
        "command": "claudeBudget.setWeeklyBudget",
        "title": "Claude Tracker: Set Weekly Budget"
      },
      {
        "command": "claudeBudget.setMonthlyBudget",
        "title": "Claude Tracker: Set Monthly Budget"
      },
      {
        "command": "claudeBudget.setProjectBudget",
        "title": "Claude Tracker: Set Project Budget"
      },
      {
        "command": "claudeBudget.pauseAlerts",
        "title": "Claude Tracker: Pause Alerts"
      },
      {
        "command": "claudeBudget.resetBudget",
        "title": "Claude Tracker: Reset All Budgets"
      }
    ],
    "configuration": {
      "title": "Claude Usage Tracker",
      "properties": {
        "claudeBudget.refreshInterval": {
          "type": "number",
          "default": 60,
          "minimum": 30,
          "description": "Refresh interval in seconds"
        },
        "claudeBudget.dataDirectory": {
          "type": "string",
          "default": "",
          "description": "Custom Claude data directory (empty = auto-detect)"
        },
        "claudeBudget.dailyBudget": {
          "type": "number",
          "default": 0,
          "description": "Daily budget limit in USD (0 = disabled)"
        },
        "claudeBudget.weeklyBudget": {
          "type": "number",
          "default": 0,
          "description": "Weekly budget limit in USD (0 = disabled)"
        },
        "claudeBudget.monthlyBudget": {
          "type": "number",
          "default": 0,
          "description": "Monthly budget limit in USD (0 = disabled)"
        },
        "claudeBudget.alertThreshold": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "maximum": 100,
          "description": "First alert threshold % (default 80%)"
        },
        "claudeBudget.projectBudgets": {
          "type": "object",
          "default": {},
          "description": "Per-project budget limits, e.g. {\"my-app\": 50, \"backend\": 30}"
        },
        "claudeBudget.timezone": {
          "type": "string",
          "default": "",
          "description": "IANA timezone for date display"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run build -- --watch",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.125.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}